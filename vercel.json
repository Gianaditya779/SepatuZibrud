{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/catalog", "dest": "/public/catalog.html" },
    { "src": "/catalog.html", "dest": "/public/catalog.html" },
    { "src": "/detail", "dest": "/public/detail.html" },
    { "src": "/detail.html", "dest": "/public/detail.html" },
    { "src": "/about", "dest": "/public/about.html" },
    { "src": "/about.html", "dest": "/public/about.html" },
    { "src": "/contact", "dest": "/public/contact.html" },
    { "src": "/contact.html", "dest": "/public/contact.html" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/admin.html", "dest": "/public/admin.html" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
